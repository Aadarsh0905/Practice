package Practice;

import java.util.*;
public class CheckSortedArray {
    public static void main(String[] args) {
        Scanner in=new Scanner(System.in);
        System.out.println("Enter the number of elements: ");
        int n=in.nextInt();
        int[]arr=new int[n];
        System.out.println("Enter the elements in the array: ");
        for(int i=0;i<n;i++){
            arr[i]=in.nextInt();
        }
        for(int i=0;i<n-1;i++){
            if(arr[i]<arr[i+1]){
                if(i==n-2) System.out.println("Sorted array is given");
            }
            else{
                System.out.println("No sorted array is to declared here");
                break;
            }
        }
    }
}
