    public static void mergeArray(long[] arr,long[] brr,int n,int m){
        int left=n-1;
        int right=0;
        while(left>=0 && right<m){
            if(arr[left]>brr[right]){
                long temp=arr[left];
                arr[left]=brr[right];
                brr[right]=temp;
                left--;
                right++;
            }
            else break;
        }
        Arrays.sort(arr);
        Arrays.sort(brr);
    }




