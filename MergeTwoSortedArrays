    //Optimal-Method2
    public static void swapIfGreater(long[] arr,long[] brr,int ind1,int ind2){
        if(arr[ind1]>brr[ind2]){
            long temp=arr[ind1];
            arr[ind1]=arr[ind2];
            arr[ind2]=temp;
        }
    }

    public static void merge(long[] arr,long[] brr,int n,int m){
        int len=(n+m);
        int gap=(len/2)+(len%2);
        while(gap>0){
            int left=0;
            int right=left+gap;
            while(right<len){
                if(left<n && right>=n)swapIfGreater(arr,brr,left,right-n);
                else if(left>=n) swapIfGreater(brr,brr,left-n,right-n);
                else swapIfGreater(arr,arr,left,right);
                left++;
                right++;
            }
            if(gap==1)break;
            else gap=(gap/2)+(gap%2);
        }
    }
