package Practice;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.Scanner;

public class IntersectionOfTwoArrays {
    public static void main(String[] args) {
        Scanner in=new Scanner(System.in);
        System.out.println("Enter the number of elements in the array1: ");
        int n=in.nextInt();
        int[]arr1=new int[n];
        System.out.println("Enter the elements in the array1: ");
        for(int i=0;i<n;i++){
            arr1[i]=in.nextInt();
        }
        System.out.println("Enter the number of elements in the array2: ");
        int m=in.nextInt();
        int[]arr2=new int[m];
        System.out.println("Enter the elements in the array2: ");
        for(int i=0;i<m;i++){
            arr2[i]=in.nextInt();
        }
        Arrays.sort(arr1);
        Arrays.sort(arr2);
        ArrayList<Integer> intersection=new ArrayList<>();
        int i=0;
        int j=0;
        while(i<n && j<m){
            if(arr1[i]<arr2[j])i++;
            else if(arr1[i]>arr2[j])j++;
            else{
                intersection.add(arr1[i]);
                i++;
                j++;
            }
        }
        System.out.println(intersection);
    }
}
