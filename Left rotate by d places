        System.out.println("Enter the number of elements: ");
        int n=in.nextInt();
        int[]arr=new int[n];
        System.out.println("Enter the elements in the array: ");
        for(int i=0;i<n;i++){
            arr[i]=in.nextInt();
        }
        System.out.println("Enter the number of times you want to left rotate this array:");
        int d=in.nextInt();
        d=d%n;
        //Brute force approach
//        ArrayList<Integer> l=new ArrayList<>();
//        for(int i=0;i<d;i++){
//            l.add(arr[i]);
//        }
//        for(int i=d;i<n;i++){
